<%- include('partials/head', { title: 'Inventory' }) %>
<%- include('partials/hud') %>
<main>
  <h1>Inventory</h1>
  <section class="card">
    <h2>Fight loadout</h2>
    <p class="muted">
      Each fight, you + your active mob bring <strong><%= (atk.weapons || []).length %></strong> weapons,
      <strong><%= (atk.armors || []).length %></strong> armors, and <strong><%= (atk.vehicles || []).length %></strong> vehicles
      (the rest sit on the shelf — so stockpiling matters).
    </p>
    <div class="grid two">
      <div>
        <h3>Offense-ranked</h3>
        <ul class="loadout">
          <% if ((atk.weapons||[]).length) { for (const i of atk.weapons) { %>
            <li>W: <%= i.name %> (+<%= i.atk %>/+<%= i.def %>)</li>
          <% } } else { %><li>no weapons</li><% } %>
          <% if ((atk.armors||[]).length) { for (const i of atk.armors) { %>
            <li>A: <%= i.name %> (+<%= i.atk %>/+<%= i.def %>)</li>
          <% } } else { %><li>no armor</li><% } %>
          <% if ((atk.vehicles||[]).length) { for (const i of atk.vehicles) { %>
            <li>V: <%= i.name %> (+<%= i.atk %>/+<%= i.def %>)</li>
          <% } } else { %><li>no vehicles</li><% } %>
        </ul>
        <p>Total bonus: <strong>+<%= totalsAtk.atk %></strong> atk / +<%= totalsAtk.def %> def</p>
      </div>
      <div>
        <h3>Defense-ranked</h3>
        <ul class="loadout">
          <% if ((def.weapons||[]).length) { for (const i of def.weapons) { %>
            <li>W: <%= i.name %> (+<%= i.atk %>/+<%= i.def %>)</li>
          <% } } else { %><li>no weapons</li><% } %>
          <% if ((def.armors||[]).length) { for (const i of def.armors) { %>
            <li>A: <%= i.name %> (+<%= i.atk %>/+<%= i.def %>)</li>
          <% } } else { %><li>no armor</li><% } %>
          <% if ((def.vehicles||[]).length) { for (const i of def.vehicles) { %>
            <li>V: <%= i.name %> (+<%= i.atk %>/+<%= i.def %>)</li>
          <% } } else { %><li>no vehicles</li><% } %>
        </ul>
        <p>Total bonus: +<%= totalsDef.atk %> atk / <strong>+<%= totalsDef.def %></strong> def</p>
      </div>
    </div>
  </section>

  <section class="card">
    <h2>All items</h2>
    <% if (inv.length === 0) { %><p class="muted">You own nothing. Do some jobs or visit the shop.</p><% } %>
    <table class="itemlist">
      <thead><tr><th>Item</th><th>Slot</th><th>Atk</th><th>Def</th><th>Qty</th></tr></thead>
      <tbody>
      <% for (const i of inv) { %>
        <tr>
          <td><%= i.name %></td>
          <td><%= i.slot %></td>
          <td>+<%= i.atk %></td>
          <td>+<%= i.def %></td>
          <td><%= i.quantity %></td>
        </tr>
      <% } %>
      </tbody>
    </table>
  </section>
</main>
<%- include('partials/foot') %>
